{
  "name": "openclaw-antigravity",
  "version": "0.2.0",
  "description": "OpenClaw provider plugin for Google Antigravity localharness",
  "type": "module",
  "bin": {
    "openclaw-antigravity": "./bin/openclaw-antigravity.mjs"
  },
  "files": [
    "bin/",
    "bridge/*.py",
    "bridge/*.sh",
    "bridge/pyproject.toml",
    "dist/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "doctor": "node ./bin/openclaw-antigravity.mjs doctor",
    "test": "node ./bin/openclaw-antigravity.mjs test"
  },
  "dependencies": {
    "ws": "^8.0.0"
  },
  "openclaw": {
    "extensions": ["./dist/index.mjs"],
    "install": {
      "npmSpec": "openclaw-antigravity",
      "defaultChoice": "npm"
    }
  },
  "license": "MIT"
}
