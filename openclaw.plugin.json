{
  "id": "google-antigravity",
  "name": "Google Antigravity",
  "description": "OpenClaw provider for Google Antigravity localharness. Requires the official google-antigravity Python package.",
  "providers": ["google-antigravity"],
  "contracts": {},
  "providerCatalogEntry": "./dist/provider.mjs",
  "activation": {
    "onStartup": false,
    "onAgentHarnesses": ["google-antigravity"]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "model": {
        "type": "string",
        "default": "gemini-3.5-flash"
      },
      "port": {
        "type": "integer",
        "default": 8080
      },
      "harnessBinary": {
        "type": "string",
        "default": ""
      }
    }
  }
}
